# Production defaults use live search plus Gemini LLM and embeddings.
RESEARCH_AGENT_SEARCH_MODE=auto
RESEARCH_AGENT_LLM_MODE=gemini
RESEARCH_AGENT_EMBEDDING_MODE=gemini
RESEARCH_AGENT_OUTPUT_DIR=runs
RESEARCH_AGENT_VECTOR_STORE=vector_store/research_agent_vectors.json

# Required for the default Gemini-backed path.
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_MODELS=gemini-2.5-flash,gemini-2.5-flash-lite,gemini-2.5-pro
# GEMINI_EMBEDDING_MODEL=gemini-embedding-2
# GEMINI_EMBEDDING_DIMENSIONS=768
# GEMINI_MAX_RETRIES=3
# GEMINI_RETRY_BACKOFF_SECONDS=1.0
# GEMINI_RETRY_MAX_BACKOFF_SECONDS=8.0
# TAVILY_API_KEY=
# SERPAPI_API_KEY=
